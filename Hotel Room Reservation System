def load_active_bookings():
    booked_rooms.clear()
    cursor.execute("SELECT id, room, name, type, days, checkin, checkout, total FROM bookings WHERE status='Booked'")
    for r in cursor.fetchall():
        booked_rooms[r[1]] = {
            "booking_id": r[0],
            "name": r[2],
            "type": r[3],
            "days": r[4],
            "checkin": r[5],
            "checkout": r[6],
            "total": r[7],
            "checkout_dt": datetime.strptime(r[6], "%Y-%m-%d %H:%M")
        }

