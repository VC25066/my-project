from PIL import Image, ImageTk
import base64
import io

LOGO_BASE64_STRING = """"""

def show_loading_screen():
    current_username = username_entry.get().strip()
    if not current_username:
        current_username = "Staff"

    loading_win = tk.Toplevel()
    loading_win.title("Initializing System")
    loading_win.geometry("500x650")
    loading_win.resizable(False, False)
    loading_win.configure(bg="#0a3d62")
    
    # Center Window Layout
    loading_win.update_idletasks()
    w, h = loading_win.winfo_width(), loading_win.winfo_height()
    x = (loading_win.winfo_screenwidth() // 2) - (w // 2)
    y = (loading_win.winfo_screenheight() // 2) - (h // 2)
    loading_win.geometry(f'{w}x{h}+{x}+{y}')
    
    # Header Titles
    tk.Label(loading_win, text="Welcome", font=("Segoe UI", 24, "bold"), fg="white", bg="#0a3d62").pack(pady=(40, 5))
    tk.Label(loading_win, text=f"{current_username.upper()}", font=("Segoe UI", 14), fg="#dcdde1", bg="#0a3d62").pack(pady=(0, 30))

    # Canvas for drawing the custom circular ring loader
    canvas_size = 300
    canvas = tk.Canvas(loading_win, width=canvas_size, height=canvas_size, bg="#0a3d62", highlightthickness=0)
    canvas.pack()

    # --- CENTER HOTEL LOGO INTEGRATION FROM STRING ---
    try:
        # Convert the text string back into image bytes safely in memory
        image_data = base64.b64decode(LOGO_BASE64_STRING)
        image_bytes = io.BytesIO(image_data)
        
        img_open = Image.open(image_bytes)
        img_resized = img_open.resize((170, 170), Image.Resampling.LANCZOS)
        logo_img = ImageTk.PhotoImage(img_resized)
        
        # Kept safely referenced to prevent Python's garbage collection from clearing the asset
        canvas.image = logo_img 
        canvas.create_image(canvas_size // 2, canvas_size // 2, image=logo_img)
    except Exception as e:
        print(f"Embedded logo error: {e}")
        canvas.create_text(canvas_size // 2, canvas_size // 2, text="[ BLUE LAGOON ]", fill="white", font=("Segoe UI", 12, "bold"))

    # Ring tracking measurements
    padding = 20
    thickness = 10
    bbox = (padding, padding, canvas_size - padding, canvas_size - padding)

    # Draw the static underlying dark blue circle track
    canvas.create_oval(bbox, outline="#233b9e", width=thickness)

    # Dynamic overlay arc loader setup (Starts at 12 o'clock)
    active_arc = canvas.create_arc(bbox, start=90, extent=0, outline="white", width=thickness, style="arc")

    # Central Status Labels matching the data framework logic updates
    status_label = tk.Label(loading_win, text="Connecting to core hotel infrastructure...", font=("Segoe UI", 11, "italic"), bg="#0a3d62", fg="#dcdde1")
    status_label.pack(pady=(30, 5))
    
    percentage_label = tk.Label(loading_win, text="0%", font=("Segoe UI", 12, "bold"), bg="#0a3d62", fg="white")
    percentage_label.pack()

    # Preserved your hotel database data array tasks
    loading_tasks = [
        (20, "Authenticating secure credentials..."),
        (45, "Loading room layout blueprints..."),
        (70, "Compiling active customer logs..."),
        (90, "Syncing reservation database matrix..."),
        (100, "System Initialization complete!")
    ]

    def advance_progress(index=0, current_val=0):
        if index < len(loading_tasks):
            target_val, message = loading_tasks[index]
            
            if current_val < target_val:
                current_val += 2
                current_extent = -360 * (current_val / 100.0)
                canvas.itemconfig(active_arc, extent=current_extent)
                percentage_label.config(text=f"{current_val}%")
                
                if current_val >= target_val:
                    status_label.config(text=message)
                    index += 1
                loading_win.after(35, lambda: advance_progress(index, current_val))
            else:
                index += 1
                loading_win.after(35, lambda: advance_progress(index, current_val))
        else:
            loading_win.destroy()
            root.destroy()
            load_active_bookings()
            launch_main_dashboard()

    loading_win.after(100, advance_progress)
    loading_win.grab_set()

