        tk.Button(scroll_win, text="SAVE INVOICE CHARGES", command=save_invoice, bg=ACCENT_TEAL, fg="white", font=("Segoe UI", 10, "bold"), bd=0).pack(pady=20, ipady=4)

    # --- Interactive Visual Room Map Frame ---
