    username_entry = tk.Entry(root, font=("Segoe UI", 12), width=25, bg="#334155", fg="white", insertbackground="white", bd=0)
    username_entry.pack(pady=8, ipady=4)

    tk.Label(root, text="Password", bg=BG_DARK, fg=TEXT_MUTED, font=("Segoe UI", 11, "bold")).pack()
