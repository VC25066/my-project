        st_frame = tk.Frame(map_frame, bg=BG_DARK)
        st_frame.pack(side="left", fill="both", expand=True, padx=5)
        grid_st = tk.Frame(st_frame, bg=BG_DARK)
        grid_st.pack(anchor="w")

        dlx_frame = tk.Frame(map_frame, bg=BG_DARK)
        dlx_frame.pack(side="right", fill="both", expand=True, padx=5)
        grid_dlx = tk.Frame(dlx_frame, bg=BG_DARK)
        grid_dlx.pack(anchor="w")

        def construct_nodes(room_list, parent_grid):
            for idx, r in enumerate(room_list):
                if r in booked_rooms:
                    b = booked_rooms[r]
                    cin = datetime.strptime(b["checkin"], "%Y-%m-%d %H:%M")
                    bg_node = COLOR_OCCUPIED if cin.date() <= today else COLOR_RESERVED
                    status_txt = "OCCUPIED" if cin.date() <= today else "RESERVED"
                else:
                    bg_node = COLOR_AVAILABLE; status_txt = "AVAILABLE"

                btn = tk.Button(parent_grid, text=f"{r}\n●", font=("Consolas", 9, "bold"), bg=bg_node, fg="white", width=7, height=2, bd=0, cursor="hand2")
                btn.grid(row=idx // 6, column=idx % 6, padx=3, pady=3)
                
                def make_cb(room_id, st_lbl):
                    return lambda e: messagebox.showinfo(f"Room {room_id}", f"Status: {st_lbl}\n" + (f"Guest: {booked_rooms[room_id]['name']}\nCheckout: {booked_rooms[room_id]['checkout']}" if room_id in booked_rooms else "Guest: None"))
                btn.bind("<Button-1>", make_cb(r, status_txt))

        construct_nodes(standard_rooms, grid_st)
        construct_nodes(deluxe_rooms, grid_dlx)

    # --- Interactive Visual Room Map Frame ---
    def refresh():
        for t in (standard_tree, deluxe_tree):
            for i in t.get_children(): t.delete(i)

        today = datetime.now().date()
        cnt_avail, cnt_res, cnt_occ, total_rev = 0, 0, 0, 0

        for room in standard_rooms:
            if room in booked_rooms:
                b = booked_rooms[room]
                cin = datetime.strptime(b["checkin"], "%Y-%m-%d %H:%M")
                status = "Active" if cin.date() <= today else "Reservation"
                if status == "Active": cnt_occ += 1
                else: cnt_res += 1
                vals = (room, b["name"], b["type"], b["days"], b["checkin"], b["checkout"], f'RM{b["total"]}', status)
                tag = 'active' if status == "Active" else 'reservation'
            else:
                cnt_avail += 1; vals = (room, "-", "-", "-", "-", "-", "-", "Available"); tag = 'available'
            standard_tree.insert("", "end", values=vals, tags=(tag,))

        for room in deluxe_rooms:
            if room in booked_rooms:
                b = booked_rooms[room]
                cin = datetime.strptime(b["checkin"], "%Y-%m-%d %H:%M")
                status = "Active" if cin.date() <= today else "Reservation"
                if status == "Active": cnt_occ += 1
                else: cnt_res += 1
                vals = (room, b["name"], b["type"], b["days"], b["checkin"], b["checkout"], f'RM{b["total"]}', status)
                tag = 'active' if status == "Active" else 'reservation'
            else:
                cnt_avail += 1; vals = (room, "-", "-", "-", "-", "-", "-", "Available"); tag = 'available'
            deluxe_tree.insert("", "end", values=vals, tags=(tag,))

        cursor.execute("SELECT total, penalty FROM bookings")
        for row in cursor.fetchall(): total_rev += row[0] + row[1]

        lbl_stat_avail.config(text=str(cnt_avail))
        lbl_stat_res.config(text=str(cnt_res))
        lbl_stat_occupied.config(text=str(cnt_occ))
        lbl_stat_rev.config(text=f"RM {total_rev:,}")

        for t in (standard_tree, deluxe_tree):
            t.tag_configure('available', background="#e2f0d9", foreground="#1e4620")
            t.tag_configure('reservation', background="#fff2cc", foreground="#7f6000")
            t.tag_configure('active', background="#fce4d6", foreground="#c65911")

        draw_interactive_map()

    def book_room():
        name = entry_name.get().strip()
        room = room_no.get().strip()
        if not name or not room or not entry_days.get():
            messagebox.showerror("Error", "Complete all requested fields")
            return
        try: days = int(entry_days.get())
        except ValueError: return
        
        if room in booked_rooms:
            messagebox.showerror("Error", "Room already booked")
            return

        checkin = datetime.strptime(date_entry.get() + " " + time_var.get(), "%Y-%m-%d %H:%M")
        if checkin <= datetime.now():
            messagebox.showerror("Booking Error", "Cannot book date/time in the past.")
            return

        checkout = checkin + timedelta(days=days)
        price = STANDARD_PRICE if room_var.get() == "Standard" else DELUXE_PRICE

        cursor.execute("INSERT INTO bookings (room, name, type, days, checkin, checkout, total, penalty, status) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)",
                       (room, name, room_var.get(), days, checkin.strftime("%Y-%m-%d %H:%M"), checkout.strftime("%Y-%m-%d %H:%M"), price * days, 0, "Booked"))
        conn.commit()
        load_active_bookings()
        refresh()
        messagebox.showinfo("Success", "Room Booked Successfully!")

    def checkout_room():
        win = tk.Toplevel(main_root)
        win.title("Room Checkout")
        win.geometry("350x220")
        win.configure(bg=BG_DARK)

        tk.Label(win, text="Checkout Room Unit:", bg=BG_DARK, fg=TEXT_LIGHT).pack(pady=10)
        checkout_room_no = tk.StringVar()
        combo = ttk.Combobox(win, textvariable=checkout_room_no, values=list(booked_rooms.keys()), state="readonly")
        combo.pack(pady=5)

        def confirm_checkout():
            room = checkout_room_no.get()
            if not room: return
            data = booked_rooms[room]
            
            penalty = 0
            if datetime.now() > data["checkout_dt"]:
                penalty = STANDARD_PENALTY if data["type"] == "Standard" else DELUXE_PENALTY

            cursor.execute("SELECT item, price FROM invoices WHERE room=?", (room,))
            invoice_items = cursor.fetchall()
            invoice_total = sum(p for _, p in invoice_items)
            final_total = data["total"] + penalty + invoice_total

            cursor.execute("UPDATE bookings SET penalty=?, status=? WHERE id=?", (penalty, "Checked Out", data["booking_id"]))
            cursor.execute("DELETE FROM invoices WHERE room=?", (room,))
            conn.commit()

            # --- DYNAMIC FILENAME GENERATION FOR TODAY'S DATE ---
            # Format today's live system date to MM-DD-YYYY (e.g. 6-23-2026)
            current_date_str = datetime.now().strftime("%m-%d-%Y")
            
            # Clean spaces from customer names to safely construct filenames
            clean_customer_name = data['name'].replace(" ", "_")
            default_invoice_filename = f"Invoice_Receipt_{clean_customer_name}_{current_date_str}.txt"

            file_path = filedialog.asksaveasfilename(
                initialfile=default_invoice_filename,
                defaultextension=".txt", 
                filetypes=[("Text files", "*.txt")], 
                title="Save Invoice As"
            )
            if file_path:
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write("BLUE LAGOON HOTEL RECEIPT\n" + "="*40 + "\n")
                    f.write(f"Customer: {data['name']}\nRoom Unit: {room} [{data['type']}]\n")
                    f.write(f"Check-In: {data['checkin']}\nCheck-Out: {data['checkout']}\n" + "-"*40 + "\n")
                    if data["type"] == "Deluxe":
                        f.write("  Breakfast (Included)\n  Room Cleaning (Included)\n")
                    for item, price in invoice_items:
                        f.write(f"  {item:<25} RM{price:.2f}\n")
                    f.write("-"*40 + f"\nBase Total: RM{data['total']:.2f}\nServices: RM{invoice_total:.2f}\nPenalty: RM{penalty:.2f}\nGrand Total: RM{final_total:.2f}\n" + "="*40)
                os.system(f'notepad "{file_path}"')

            load_active_bookings()
            refresh()
            win.destroy()

        tk.Button(win, text="CONFIRM DISCHARGE", command=confirm_checkout, bg=COLOR_OCCUPIED, fg="white", font=("Segoe UI", 10, "bold"), bd=0).pack(pady=15, ipady=4)

    def export_booking_history():
        # --- DYNAMIC FILENAME GENERATION FOR TODAY'S DATE ---
        # Format today's live system date to MM-DD-YYYY (e.g. 6-23-2026)
        current_date_str = datetime.now().strftime("%m-%d-%Y")
        default_history_filename = f"Booking_History_{current_date_str}.csv"

