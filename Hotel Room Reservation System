        def save_invoice():
            room = room_var_invoice.get().strip()
            if not room: return
            
            # Identify current room class type structure
            room_type_class = booked_rooms[room]['type'] if room in booked_rooms else "Standard"
            
            total = 0
            selected_items = []

            # 1. Process Quantities
            for item, var in qty_vars.items():
                try:
                    qty = int(var.get())
                except ValueError:
                    qty = 0
                if qty > 0:
                    if "Towel" in item or "Blanket" in item:
                        price = 5 * qty
                    elif "Pillow" in item:
                        price = 2.5 * qty
                    elif "Snacks" in item:
                        price = 3 * qty
                    elif "Drinks" in item:
                        price = 4 * qty
                    total += price
                    clean_name = item.split(" (")[0]
                    selected_items.append((f"{clean_name} (x{qty})", price))

            # 2. Process Checkboxes
            for item, var in bool_vars.items():
                if var.get():
                    # If Deluxe room class, exclude Breakfast & Room Cleaning from charges matrix
                    if room_type_class == "Deluxe" and ("Breakfast" in item or "Room Cleaning" in item):
                        continue

                    if "Breakfast" in item or "Lunch" in item or "Dinner" in item:
                        price = 15
                        total += price
                        selected_items.append((item, price))
                    elif "Damage" in item:
                        price = 60
                        total += price
                        selected_items.append((item, price))
                    elif "Missing" in item:
                        price = 100
                        total += price
                        selected_items.append((item, price))
                    elif "Cleaning" in item:
                        tax = total * 0.08
                        total += tax
                        selected_items.append((item, tax))
                    elif "Luggage" in item:
                        tax = total * 0.05
                        total += tax
                        selected_items.append((item, tax))
                    elif "Reception" in item:
                        tax = total * 0.09
                        total += tax
                        selected_items.append((item, tax))

            cursor.execute("DELETE FROM invoices WHERE room = ?", (room,))
            for itm, prc in selected_items:
                cursor.execute("INSERT INTO invoices (room, item, price) VALUES (?, ?, ?)", (room, itm, prc))
            conn.commit()
            messagebox.showinfo("Saved", f"Invoice updated for room {room}. Add-ons Total: RM{total:.2f}")
